<div class="c-modal" id="modal-corso" data-controller="modal">
  <div class="c-modal__overlay" data-action="click-&gt;modal#close"></div>
  <div class="c-modal__close" data-action="click-&gt;modal#close">
    <i class="icon-x"></i>
  </div>

  <div class="c-modal__section">
    <div class="c-modal__content">
      <div class="c-modal__scroll" data-modal-target="scroll">
        <div class="c-modal-course__step1" data-modal-target="step" data-step="step1">
          <div class="c-modal__title">
            <h2 class="title">Entra a far parte del nostro team!</h2>
            <p>Vuoi diventare un nuovo allievo dell’Academy?</p>
          </div>

          <div class="c-modal-course__select-title">
            <h3>Seleziona come vuoi essere ricontattato</h3>
          </div>
          <div class="c-modal-course__select">
            <div class="c-modal-course__option" data-action="click-&gt;modal#changeStep" data-current="step1" data-next="step2" data-value="email">
<i class="icon-mail"></i> Email</div>
            <div class="c-modal-course__option" data-action="click-&gt;modal#changeStep" data-current="step1" data-next="step2" data-value="whatsapp">
<i class="icon-whatsapp"></i> Whatsapp</div>
          </div>
        </div>

        <div class="c-modal-course__step2" data-modal-target="step" data-step="step2">
          <div class="c-modal__title">
            <h2 class="title">Entra a far parte del nostro team!</h2>
            <p>Vuoi diventare un nuovo allievo dell’Academy?</p>
          </div>
  
          <form class="c-form" data-controller="form choices" action="https://resinenativus.it/wp-admin/admin-ajax.php" enctype="multipart/form-data" method="POST">
            <input type="hidden" name="_form" value="course">
            <input type="hidden" name="action" value="custom_ajax_mailer">
            <input type="hidden" name="honey" value="">
            <input type="hidden" name="tipo_contatto" id="contatto-step" value="">

            <div class="c-form__select c-form__select--full">
              <label for="richiesta" class="c-form__label">Come possiamo aiutarti?*</label>
              <select name="richiesta" id="richiesta" data-choices-target="select" required>
                <option value="" disabled selected>Seleziona la richiesta</option>
                
                <option value="Info generali sull'academy">Info generali sull'academy</option>
                <option value="I fondamentali">I fondamentali</option>
                <option value="Workshop">Workshop</option>
              </select>
            </div>

            <div class="c-form__input">
              <label for="nome" class="c-form__label">Nome*</label>
              <input type="text" id="nome" name="nome" placeholder="Nome" required>
            </div>
  
            <div class="c-form__input">
              <label for="cognome" class="c-form__label">Cognome*</label>
              <input type="text" id="cognome" name="cognome" placeholder="Cognome" required>
            </div>
  
            <div class="c-form__input">
              <label for="email" class="c-form__label">Email*</label>
              <input type="email" id="email" name="email" placeholder="Inserisci un'email valida" required>
            </div>
  
            <div class="c-form__input">
              <label for="telefono" class="c-form__label">Telefono*</label>
              <input type="text" id="telefono" name="telefono" placeholder="Inserisci un recapito" required>
            </div>


            <div class="c-form__select">
              <label for="settore" class="c-form__label">Settore aziendale*</label>
              <select name="settore" id="settore" data-choices-target="select" required>
                <option value="" disabled selected>Seleziona il settore</option>
                
                <option value="Applicatore">Applicatore</option>
                <option value="Rivenditore">Rivenditore</option>
                <option value="Impresario">Impresario</option>
                <option value="Agente">Agente</option>
              </select>
            </div>

            <div class="c-form__input">
              <label for="azienda" class="c-form__label">Azienda*</label>
              <input type="text" id="azienda" name="azienda" placeholder="Inserisci la tua azienda" required>
            </div>

            <div class="c-form__input">
              <label for="partita_iva" class="c-form__label">P.IVA*</label>
              <input type="text" id="partita_iva" name="partita_iva" placeholder="Inserisci la tua Parita IVA" required>
