          <div class="c-form__select c-form__select--full">
            <label for="richiesta_contatto" class="c-form__label">Tipo di richiesta</label>
            <select name="richiesta_contatto" id="richiesta_contatto" data-choices-target="select">
              <option value="" disabled selected>Seleziona la richiesta</option>
              
              <option value="Informazioni generali">Informazioni generali</option>
              <option value="Richiesta consulenza per un progetto">Richiesta consulenza per un progetto</option>
              <option value="Richiesta supporto per posa o manutenzione">Richiesta supporto per posa o manutenzione</option>
              <option value="Richiesta preventivo">Richiesta preventivo</option>
              <option value="Ricerca rivenditore di zona">Ricerca rivenditore di zona</option>
              <option value="Richiesta di collaborazione per progetti">Richiesta di collaborazione per progetti</option>
            </select>
          </div>

          <div class="c-form__input c-form__input--full">
            <label for="messaggio_contatto" class="c-form__label">Messaggio</label>
            <textarea name="messaggio_contatto" id="messaggio_contatto"></textarea>
          </div>

          <div class="c-form__checkbox">
            <label for="privacy_contatto">
              <input type="checkbox" name="privacy_contatto" id="privacy_contatto">
              <span class="checkmark"></span>
              <span>Acconsento al trattamento dei dati personali *</span>
            </label>
          </div>

          <div class="c-form__submit">
            <button type="submit" class="c-button" data-gsap-cta>
              <div class="c-button__bg"></div>
              <span>Invia</span>
            </button>
          </div>

          <div class="c-form__feedback" data-form-target="feedback">
            <h2 class="title">La tua richiesta è stata inviata</h2>
            <div class="text">
              <p>Una persona specializzata del nostro team ti risponderà nelle prossime 24 ore.</p>
              <p>Contattaci anche su <a href="https://wa.me/" class="h-text-underline" target="_blank">Whatsapp</a></p>
            </div>
            <button class="c-button" data-gsap-cta data-action="click-&gt;modal#close">
              <div class="c-button__bg"></div>
              <span>Torna al sito</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<div class="c-modal c-modal--gallery" id="modal-slider" data-modalslider-target="modal">
  <div class="c-modal__overlay" data-action="click-&gt;modalslider#close"></div>
  <div class="c-modal__close" data-action="click-&gt;modal#close">
    <i class="icon-x"></i>
  </div>

  <div class="c-modal__section c-modal__section--gallery">
    <div class="c-modal__content">

      <div class="c-modal__slider splide" data-modalslider-target="slider">
        <div class="splide__track">
          <ul class="splide__list">
            
          </ul>
        </div>
      </div>

    </div>
  </div>
</div>
<div class="c-modal" id="modal-reserved" data-controller="modal">
  <div class="c-modal__overlay" data-action="click-&gt;modal#close"></div>

  <div class="c-modal__close" data-action="click-&gt;modal#close">
    <i class="icon-x"></i>
  </div>

  <div class="c-modal__section">  
    <div class="c-modal__content">
      <div class="c-modal__scroll" data-modal-target="scroll">
        <div class="c-modal__title">
          <h2 class="title">Documento riservato</h2>
        </div>

        <div class="text">
          <p>Questo documento è utilizzabile solamente dagli utenti registrati che possiedono i permessi di visualizzazione</p>
        </div>
        
      </div>
    </div>
  </div>
</div>
